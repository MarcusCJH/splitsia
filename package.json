{
  "name": "splitleh",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "lite/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @splitleh/lite-web",
    "build": "npm run build -w @splitleh/lite-web",
    "preview": "npm run preview -w @splitleh/lite-web",
    "deploy": "npm run deploy -w @splitleh/lite-web",
    "bundle:lambda": "uv run python cloud/infra/scripts/bundle_lambda.py",
    "test": "npm run test -w @splitleh/core",
    "test:api": "uv run --directory cloud/api pytest tests -q",
    "test:all": "npm test && npm run test:api",
    "test:watch": "npm run test -w @splitleh/core -- --watch"
  }
}
